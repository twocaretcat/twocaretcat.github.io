{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"files": {
		"includes": [
			"**/*",
			"!**/node_modules/**/*",
			"!**/public/**/*",
			"!**/plugins/**/*",
			"!**/.cache/**/*",
			"!**/.*",
			"!**/gatsby-types.d.ts"
		]
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"formatter": {
		"indentStyle": "tab"
	},
	"linter": {
		"rules": {
			"correctness": {
				"noUnusedImports": {
					"level": "warn",
					"fix": "none"
				},
				"noNodejsModules": "off"
			},
			"style": {
				"noImplicitBoolean": "off"
			},
			"suspicious": {
				"noReactSpecificProps": "off",
				"noConsole": "off"
			}
		}
	},
	"css": {
		"formatter": {
			"quoteStyle": "single"
		},
		"parser": {
			"tailwindDirectives": true
		}
	},
	"javascript": {
		"jsxRuntime": "transparent",
		"formatter": {
			"quoteStyle": "single"
		},
		"globals": ["Queries", "React"]
	},
	"overrides": [
		{
			"includes": ["**/src/styles/global.css"],
			"linter": {
				"rules": {
					"suspicious": {
						"noUnknownAtRules": "off"
					}
				}
			}
		},
		{
			"includes": ["**/src/config/github-repos.ts"],
			"linter": {
				"domains": {
					"project": "recommended",
					"react": "recommended",
					"test": "recommended",
					"types": "recommended"
				},
				"rules": {
					"style": {
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"includes": ["**/404.tsx"],
			"linter": {
				"rules": {
					"style": {
						"useFilenamingConvention": "off"
					}
				}
			}
		},
		{
			"includes": ["**/card.tsx"],
			"linter": {
				"rules": {
					"style": {
						"useNamingConvention": "off"
					}
				}
			}
		}
	]
}
